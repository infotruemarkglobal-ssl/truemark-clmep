# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Source maps — uploaded to Sentry then deleted by deleteSourceMapsAfterUpload.
# Listed here as defence-in-depth: if a build step doesn't run withSentryConfig
# (e.g. a manual next build without the Sentry plugin) the maps still won't be
# committed or pushed. The /.next/ entry above already covers the normal build
# output; these catch any stray maps generated elsewhere.
*.js.map
*.js.map.gz

/src/generated/prisma

# Private file uploads (served via /api/files/url, not statically)
private-uploads/
zap-report*.html
zap.yaml
